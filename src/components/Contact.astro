---
---
<section class="py-40 relative overflow-hidden reveal" id="contact">
    <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-32 items-start">
            <div class="animate-fade-in-up">
                <h2 class="font-headline-xl text-headline-xl text-white mb-8 tracking-tight">¿Hablamos sobre tu <span class="text-primary-fixed">próximo gran paso</span>?</h2>
                <p class="font-body-lg text-body-lg text-on-surface-variant mb-16 leading-relaxed opacity-90">
                    Nos encanta escuchar nuevas ideas. Ya sea que estés empezando desde cero o quieras mejorar lo que ya tienes, queremos ser tu aliado tecnológico y ayudarte a crecer.
                </p>
                <div class="space-y-10">
                    <div class="flex items-center gap-6">
                        <div class="w-14 h-14 glass-card-refined rounded flex items-center justify-center text-primary-fixed border border-outline-variant/20">
                            <span class="material-symbols-outlined">chat_bubble</span>
                        </div>
                        <div>
                            <p class="font-label-mono text-label-mono text-outline uppercase tracking-widest mb-1">Contacto Directo</p>
                            <p class="font-headline-md text-headline-md text-white">hola@nexodev.studio</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-6">
                        <div class="w-14 h-14 glass-card-refined rounded flex items-center justify-center text-primary-fixed border border-outline-variant/20">
                            <span class="material-symbols-outlined">handshake</span>
                        </div>
                        <div>
                            <p class="font-label-mono text-label-mono text-outline uppercase tracking-widest mb-1">Alianzas</p>
                            <p class="font-headline-md text-headline-md text-white">Hagamos equipo</p>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="glass-card-refined p-12 rounded precision-border animate-fade-in-up delay-200">
                <form class="space-y-8" onsubmit="event.preventDefault();">
                    <div>
                        <label class="block font-label-mono text-label-mono text-primary-fixed mb-3 uppercase tracking-widest">¿Cómo te llamas?</label>
                        <input class="w-full bg-surface-container-highest border border-outline-variant/20 rounded p-4 text-white focus:border-primary-fixed focus:ring-0 outline-none transition-all placeholder:text-outline-variant/50" placeholder="Tu nombre o el de tu marca" type="text" required/>
                    </div>
                    <div>
                        <label class="block font-label-mono text-label-mono text-primary-fixed mb-3 uppercase tracking-widest">¿A dónde te escribimos?</label>
                        <input class="w-full bg-surface-container-highest border border-outline-variant/20 rounded p-4 text-white focus:border-primary-fixed focus:ring-0 outline-none transition-all placeholder:text-outline-variant/50" placeholder="tu@email.com" type="email" required/>
                    </div>
                    <div>
                        <label class="block font-label-mono text-label-mono text-primary-fixed mb-3 uppercase tracking-widest">¿Qué tienes en mente?</label>
                        <textarea class="w-full bg-surface-container-highest border border-outline-variant/20 rounded p-4 text-white focus:border-primary-fixed focus:ring-0 outline-none transition-all placeholder:text-outline-variant/50" placeholder="Queremos conocer tu proyecto..." rows="5" required></textarea>
                    </div>
                    <button class="w-full bg-primary-fixed text-on-primary-fixed py-5 rounded font-bold text-lg hover:shadow-[0_0_20px_rgba(99,247,255,0.4)] transition-all flex items-center justify-center gap-3 active:scale-[0.99]" type="submit">
                        EMPEZAR AHORA <span class="material-symbols-outlined">send</span>
                    </button>
                </form>
            </div>
        </div>
    </div>
</section>