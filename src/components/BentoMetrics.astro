---
---
<section id="metricas" class="py-20 relative border-t border-white/5 bg-[#02040a]">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    
    <div class="mb-12">
      <p class="text-xs font-mono text-cyan-400 uppercase tracking-widest">// CRITERIOS DE INGENIERÍA</p>
      <h2 class="text-2xl sm:text-3xl font-bold text-white mt-1">Métricas y Resiliencia</h2>
    </div>

    <!-- Bento Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      
      <!-- Tarjeta 1: Estabilidad (Doble Columna) -->
      <div class="md:col-span-2 relative overflow-hidden rounded-2xl border border-white/10 bg-white/[0.01] p-8 backdrop-blur-md flex flex-col justify-between group hover:border-cyan-500/30 transition-all duration-300">
        <div class="absolute top-0 right-0 h-32 w-32 bg-cyan-500/5 rounded-full blur-2xl pointer-events-none"></div>
        
        <div class="flex items-center justify-between">
          <span class="font-mono text-xs text-cyan-400">// DISPONIBILIDAD ESTABLE</span>
          <div class="p-2 rounded-lg bg-cyan-500/10 text-cyan-400">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
        </div>

        <div class="mt-12">
          <span class="text-5xl sm:text-6xl font-bold text-white tracking-tight">99.9%</span>
          <h3 class="text-lg font-semibold text-slate-200 mt-2">Disponibilidad del Motor</h3>
          <p class="text-sm text-slate-400 mt-2 max-w-md">
            Despliegues configurados bajo arquitecturas optimizadas para cargas dinámicas y entrega de contenido con mínima latencia de red.
          </p>
        </div>
      </div>

      <!-- Tarjeta 2: Stack Activo -->
      <div class="relative overflow-hidden rounded-2xl border border-white/10 bg-white/[0.01] p-8 backdrop-blur-md flex flex-col justify-between group hover:border-purple-500/30 transition-all duration-300">
        <div class="absolute top-0 right-0 h-32 w-32 bg-purple-500/5 rounded-full blur-2xl pointer-events-none"></div>

        <div class="flex items-center justify-between">
          <span class="font-mono text-xs text-purple-400">// TECNOLOGÍAS</span>
          <div class="p-2 rounded-lg bg-purple-500/10 text-purple-400">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4" />
            </svg>
          </div>
        </div>

        <div class="mt-8">
          <span class="text-4xl font-bold text-white tracking-tight">Stack Activo</span>
          <div class="text-xs font-mono text-slate-400 mt-4 flex flex-wrap gap-2">
            <span class="px-2 py-1 rounded bg-white/5 border border-white/10">Astro</span>
            <span class="px-2 py-1 rounded bg-white/5 border border-white/10">React</span>
            <span class="px-2 py-1 rounded bg-white/5 border border-white/10">TypeScript</span>
            <span class="px-2 py-1 rounded bg-white/5 border border-white/10">Tailwind</span>
            <span class="px-2 py-1 rounded bg-white/5 border border-white/10">MongoDB</span>
          </div>
        </div>
      </div>

      <!-- Tarjeta 3: Calidad de Software -->
      <div class="relative overflow-hidden rounded-2xl border border-white/10 bg-white/[0.01] p-8 backdrop-blur-md flex flex-col justify-between group hover:border-emerald-500/30 transition-all duration-300">
        <div class="absolute top-0 right-0 h-32 w-32 bg-emerald-500/5 rounded-full blur-2xl pointer-events-none"></div>

        <div class="flex items-center justify-between">
          <span class="font-mono text-xs text-emerald-400">// ESTÁNDAR</span>
          <div class="p-2 rounded-lg bg-emerald-500/10 text-emerald-400">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
        </div>

        <div class="mt-8">
          <span class="text-5xl font-bold text-white tracking-tight">A+</span>
          <h3 class="text-lg font-semibold text-slate-200 mt-2">Garantía de Calidad</h3>
          <p class="text-sm text-slate-400 mt-1">
            Código limpio, semántico, accesible y estructurado bajo las mejores prácticas.
          </p>
        </div>
      </div>

      <!-- Tarjeta 4: Despliegue de Infraestructura (Doble Columna) -->
      <div class="md:col-span-2 relative overflow-hidden rounded-2xl border border-white/10 bg-white/[0.01] p-8 backdrop-blur-md flex flex-col justify-between group hover:border-slate-500/30 transition-all duration-300">
        <div class="flex items-center justify-between">
          <span class="font-mono text-xs text-slate-400">// CONTROL Y DEPLOY</span>
          <span class="text-[10px] font-mono text-emerald-400 flex items-center gap-1.5">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-500 animate-ping"></span>
            PIPELINES OK
          </span>
        </div>

        <div class="mt-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
          <div>
            <h3 class="text-lg font-semibold text-slate-200">Entorno y Distribución</h3>
            <p class="text-sm text-slate-400 mt-1 max-w-md">
              Configuraciones para un ciclo rápido de integración y despliegue continuo en plataformas de cómputo en la nube.
            </p>
          </div>
          <div class="flex gap-2 flex-wrap">
            <span class="px-2.5 py-1.5 rounded-lg bg-white/5 border border-white/5 text-[11px] font-mono text-slate-300">GitHub</span>
            <span class="px-2.5 py-1.5 rounded-lg bg-white/5 border border-white/5 text-[11px] font-mono text-slate-300">Vercel</span>
            <span class="px-2.5 py-1.5 rounded-lg bg-white/5 border border-white/5 text-[11px] font-mono text-slate-300">Netlify</span>
            <span class="px-2.5 py-1.5 rounded-lg bg-white/5 border border-white/5 text-[11px] font-mono text-slate-300">Render</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>