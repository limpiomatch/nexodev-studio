---
import { ShieldCheck, MapPin, Users, Layers } from 'lucide-react';
---

<div class="relative rounded-3xl border border-white/[0.05] bg-gradient-to-br from-white/[0.03] to-transparent backdrop-blur-2xl p-8 md:p-12 overflow-hidden shadow-2xl">
  <!-- Glow azul sutil de fondo exclusivo para este producto -->
  <div class="absolute -right-20 -bottom-20 w-80 h-80 bg-indigo-500/5 blur-[100px] rounded-full pointer-events-none"></div>

  <div class="flex flex-col lg:flex-row gap-8 items-start lg:items-center relative z-10">
    
    <!-- Info del Producto -->
    <div class="flex-1">
      <div class="inline-flex items-center gap-1.5 bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 text-xs px-3 py-1 rounded-full font-medium mb-4">
        <Layers class="w-3.5 h-3.5" /> Proyecto MVP / Incubadora
      </div>
      <h3 class="text-3xl md:text-4xl font-extrabold tracking-tight text-white">Clean Match App</h3>
      <p class="text-slate-300 mt-4 text-base font-light leading-relaxed max-w-2xl">
        Una solución de base tecnológica concebida como una Aplicación Web Progresiva (PWA). Está diseñada estratégicamente para conectar de manera segura y eficiente al personal verificado de cuidado y aseo doméstico con los hogares locales.
      </p>
      
      <!-- Características con iconos UX modernos -->
      <div class="grid sm:grid-cols-3 gap-4 mt-8">
        <div class="flex items-center gap-2.5 text-slate-400 text-sm">
          <MapPin class="w-4 h-4 text-indigo-400 shrink-0" />
          <span>Geolocalización Andes</span>
        </div>
        <div class="flex items-center gap-2.5 text-slate-400 text-sm">
          <ShieldCheck class="w-4 h-4 text-indigo-400 shrink-0" />
          <span>Perfiles Auditados</span>
        </div>
        <div class="flex items-center gap-2.5 text-slate-400 text-sm">
          <Users class="w-4 h-4 text-indigo-400 shrink-0" />
          <span>Panel de Gestión</span>
        </div>
      </div>
    </div>

    <!-- Bloque de Estado Comercial -->
    <div class="w-full lg:w-auto bg-slate-950/60 border border-white/[0.05] p-6 rounded-2xl text-center min-w-[280px] backdrop-blur-sm">
      <span class="text-[10px] uppercase font-mono tracking-widest text-slate-500 block">Estado de Operación</span>
      <span class="text-xl font-bold text-emerald-400 mt-1 block">Fase de Lanzamiento</span>
      
      <div class="h-px bg-white/[0.05] my-4"></div>
      
      <p class="text-xs text-slate-400 font-light px-2 mb-4">
        Modelo de negocio escalable e infraestructura lista para despliegue.
      </p>
      
      <a
        href="https://wa.me/573226933654?text=Hola%20Juan%20David,%20me%20interesa%20conocer%20la%20propuesta%20de%20Clean%20Match"
        target="_blank"
        rel="noopener noreferrer"
        class="block w-full py-3 bg-indigo-600 hover:bg-indigo-500 text-white font-semibold text-xs uppercase tracking-wider rounded-xl transition-all duration-200"
      >
        Solicitar Pitch Comercial
      </a>
    </div>

  </div>
</div>