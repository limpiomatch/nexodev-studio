---
import { PROJECTS } from '../data/data';
---
<section class="py-32 reveal" id="work">
    <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
        <div class="flex justify-between items-end mb-20 border-b border-outline-variant/10 pb-10 animate-fade-in-up">
            <div>
                <h2 class="font-headline-lg text-headline-lg text-white mb-4">Proyectos Que Nos Inspiran</h2>
                <p class="font-body-md text-body-md text-on-surface-variant">Conoce cómo hemos ayudado a otras marcas a dar el salto al mundo digital con éxito.</p>
            </div>
            <div class="font-label-mono text-label-mono text-outline-variant tracking-widest hidden md:block">IMPULSANDO IDEAS // 2024</div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
            {PROJECTS.map((project, index) => (
                <div class={`group project-card animate-fade-in-up delay-${(index + 1) * 100}`}>
                    <div class="relative overflow-hidden rounded mb-8 glass-card-refined aspect-video flex items-center justify-center border border-outline-variant/20">
                        <div
                            class="absolute inset-0 bg-cover bg-center transition-transform duration-1000 group-hover:scale-105 opacity-20 group-hover:opacity-40 grayscale"
                            style={`background-image: url('${project.imageUrl}')`}
                        ></div>
                        <div class="relative z-10 text-center">
                            <span class="font-label-mono text-label-mono text-primary-fixed border border-primary-fixed/30 px-6 py-2 rounded-full">
                                {project.tag}
                            </span>
                        </div>
                    </div>
                    <h3 class="font-headline-md text-headline-md text-white mb-3">{project.title}</h3>
                    <p class="font-body-md text-body-md text-on-surface-variant mb-6">{project.description}</p>
                    <div class="flex gap-4 flex-wrap">
                        {project.technologies.map(tech => (
                            <span class="font-label-mono text-[11px] uppercase tracking-widest text-outline border border-outline/20 px-2 py-1">
                                {tech}
                            </span>
                        ))}
                    </div>
                    {project.url && (
                        <a
                            href={project.url}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="inline-flex items-center gap-2 mt-4 text-primary-fixed font-label-mono text-label-mono hover:underline transition-all"
                        >
                            Ver proyecto <span class="material-symbols-outlined text-base">arrow_outward</span>
                        </a>
                    )}
                </div>
            ))}
        </div>
    </div>
</section>