---
import { CONTACT } from "../data/data";
---

<footer
    class="bg-surface/50 backdrop-blur-sm border-t border-outline-variant/10 w-full py-4"
>
    <div
        class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop"
    >
        <!-- Top Row -->
        <div
            class="flex flex-col md:flex-row justify-between items-center gap-12 mb-6"
        >
            <!-- Brand -->
            <div
                onclick="window.scrollTo({ top: 0, behavior: 'smooth' })"
                class=" cursor-pointer font-headline-md text-headline title-nexo font-bold tracking-tighter"
            >
                NexoDev<span class="title-studio">Studio</span>
            </div>

            <!-- Nav links -->
            <nav class="flex gap-8">
                <a
                    class="text-on-surface-variant hover:text-primary-fixed transition-colors font-label-mono text-label-mono tracking-widest"
                    href="#methodology">METODOLOGÍA</a
                >
                <a
                    class="text-on-surface-variant hover:text-primary-fixed transition-colors font-label-mono text-label-mono tracking-widest"
                    href="#work">PROYECTOS</a
                >
                <a
                    class="text-on-surface-variant hover:text-primary-fixed transition-colors font-label-mono text-label-mono tracking-widest"
                    href="#contact">CONTACTO</a
                >
            </nav>
        </div>

        <!-- Social Row -->
        <div
            class="flex flex-col sm:flex-row justify-between items-center gap-8"
        >
            <!-- Social Icons -->
            <div class="flex items-center gap-4">
                <!-- WhatsApp -->
                <a
                    href={`https://wa.me/${CONTACT.whatsapp}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Escríbenos por WhatsApp"
                    class="social-icon-btn group"
                    title={CONTACT.whatsappDisplay}
                >
                    <svg
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        class="w-5 h-5"
                    >
                        <path
                            d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.464 3.488"
                        ></path>
                    </svg>
                    <span class="social-tooltip">WhatsApp</span>
                </a>

                <!-- Instagram -->
                <a
                    href={CONTACT.instagram}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Síguenos en Instagram"
                    class="social-icon-btn group"
                    title={CONTACT.instagramHandle}
                >
                    <svg
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        class="w-5 h-5"
                    >
                        <path
                            d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
                        ></path>
                    </svg>
                    <span class="social-tooltip">Instagram</span>
                </a>

                <!-- Llamar -->
                <a
                    href={`tel:${CONTACT.phone}`}
                    aria-label="Llámanos"
                    class="social-icon-btn group"
                    title={CONTACT.phoneDisplay}
                >
                    <svg
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        class="w-5 h-5"
                    >
                        <path
                            d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"
                        ></path>
                    </svg>
                    <span class="social-tooltip">Llamar</span>
                </a>

                <!-- Email -->
                <a
                    href={`mailto:${CONTACT.email}`}
                    aria-label="Envíanos un email"
                    class="social-icon-btn group"
                    title={CONTACT.email}
                >
                    <svg
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        class="w-5 h-5"
                    >
                        <path
                            d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"
                        ></path>
                    </svg>
                    <span class="social-tooltip">Email</span>
                </a>

                <!-- Tarjeta de contacto (vCard / compartir) -->
                <button
                    id="share-contact-btn"
                    aria-label="Compartir tarjeta de contacto"
                    class="social-icon-btn group"
                    title="Guardar contacto"
                >
                    <svg
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        class="w-5 h-5"
                    >
                        <path
                            d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm-8 2.75c1.24 0 2.25 1.01 2.25 2.25S13.24 11.25 12 11.25 9.75 10.24 9.75 9 10.76 6.75 12 6.75zM17 17H7v-.75c0-1.66 2.69-2.5 5-2.5s5 .84 5 2.5V17z"
                        ></path>
                    </svg>
                    <span class="social-tooltip">Guardar contacto</span>
                </button>
            </div>

            <!-- Copyright -->
            <div
                class="text-on-surface-variant font-label-mono text-label-mono text-center md:text-right opacity-60 uppercase"
            >
                © 2024 NexoDevStudio. Innovando juntos desde el día uno.
            </div>
        </div>
    </div>
</footer>

<style>
    .social-icon-btn {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 44px;
        height: 44px;
        border-radius: 10px;
        border: 1px solid rgba(0, 115, 203, 0.397);
        background: rgba(0, 49, 141, 0.61);
        color: var(--color-on-surface-variant);
        cursor: pointer;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        text-decoration: none;
    }

    .social-icon-btn:hover {
        color: #fff;
        background: rgba(0, 115, 203, 0.3);
        border-color: rgba(0, 115, 203, 0.6);
        transform: translateY(-3px);
        box-shadow: 0 8px 20px -4px rgba(0, 115, 203, 0.35);
    }

    .social-tooltip {
        position: absolute;
        bottom: calc(100% + 8px);
        left: 50%;
        transform: translateX(-50%);
        background: rgba(0, 56, 146, 0.95);
        border: 1px solid rgba(0, 115, 203, 0.4);
        color: #fff;
        font-size: 11px;
        font-family: "Geist", sans-serif;
        font-weight: 500;
        letter-spacing: 0.05em;
        white-space: nowrap;
        padding: 5px 10px;
        border-radius: 6px;
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.2s ease;
    }

    .social-icon-btn:hover .social-tooltip {
        opacity: 1;
    }
</style>

<script
    define:vars={{
        contactEmail: CONTACT.email,
        contactPhone: CONTACT.phone,
        contactPhoneDisplay: CONTACT.phoneDisplay,
        contactInstagramHandle: CONTACT.instagramHandle,
        contactWhatsappDisplay: CONTACT.whatsappDisplay,
    }}
>
    // vCard download
    const shareBtn = document.getElementById("share-contact-btn");
    if (shareBtn) {
        shareBtn.addEventListener("click", () => {
            const vcardData = `BEGIN:VCARD
VERSION:3.0
FN:NexoDevStudio
ORG:NexoDevStudio
TEL;TYPE=CELL:${contactPhone}
EMAIL:${contactEmail}
URL:https://nexodev.studio
NOTE:Desarrollo web y soluciones digitales
END:VCARD`;

            const blob = new Blob([vcardData], { type: "text/vcard" });
            const url = URL.createObjectURL(blob);
            const a = document.createElement("a");
            a.href = url;
            a.download = "NexoDevStudio.vcf";
            a.click();
            URL.revokeObjectURL(url);
        });
    }
</script>
