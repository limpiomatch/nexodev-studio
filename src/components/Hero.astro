---
---
<section class="relative min-h-[90vh] flex items-center pt-20 overflow-hidden reveal active">
    <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop w-full relative z-10">
        <div class="max-w-4xl animate-fade-in-up">
            <span class="inline-block font-label-mono text-label-mono text-primary-fixed mb-8 tracking-[0.2em] uppercase">
                Innovación, Cercanía y Resultados
            </span>
            <h1 class="font-headline-xl text-headline-xl text-white mb-8 leading-[1.05] tracking-tight">
                CREAMOS SOLUCIONES DIGITALES QUE <span class="text-primary-fixed">IMPULSAN TU NEGOCIO</span>
            </h1>
            <p class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl mb-12 opacity-90">
                Somos NexoDevStudio, un equipo apasionado que nace hoy para transformar tus ideas en plataformas web potentes, seguras y muy fáciles de usar. Te acompañamos paso a paso para que tu proyecto alcance el éxito.
            </p>
            <div class="flex flex-wrap gap-6">
                <a class="bg-primary-fixed text-on-primary-fixed px-8 py-4 rounded font-bold hover:shadow-[0_0_20px_rgba(99,247,255,0.4)] transition-all active:scale-95" href="#contact">
                    Iniciar una conversación
                </a>
                <a class="border border-outline-variant text-white px-8 py-4 rounded font-medium hover:bg-white/5 transition-all active:scale-95" href="#work">
                    Ver nuestros proyectos
                </a>
            </div>
        </div>
    </div>
    
    <!-- Coordinates Decorative -->
    <div class="absolute bottom-12 right-margin-desktop hidden lg:block font-label-mono text-label-mono text-outline-variant/30">
        NEXODEVSTUDIO // STARTUP LAUNCH // READY
    </div>
</section>
